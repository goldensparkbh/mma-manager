{
  "expo": {
    "name": "Nawady",
    "slug": "dojo-member",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dojo-member",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/nawady-logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#004aad"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dojomanager.member",
      "infoPlist": {
        "NSCameraUsageDescription": "Show your membership QR code for check-in",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#004aad"
      },
      "package": "com.dojomanager.member"
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#004aad"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://orca-app-afy8n.ondigitalocean.app",
      "router": {},
      "eas": {
        "projectId": "ac417661-6282-4015-8195-437da92cb09b"
      }
    },
    "owner": "goldenspark",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ac417661-6282-4015-8195-437da92cb09b"
    }
  }
}
