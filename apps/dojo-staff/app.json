{
  "expo": {
    "name": "Nawady Staff",
    "slug": "dojo-staff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dojo-staff",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/nawady-logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#004aad"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dojomanager.staff",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan member QR codes for check-in"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#004aad"
      },
      "package": "com.dojomanager.staff",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan member QR codes for check-in"
        }
      ],
      "expo-asset",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#004aad"
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://orca-app-afy8n.ondigitalocean.app"
    }
  }
}
