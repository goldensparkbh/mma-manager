{
  "expo": {
    "name": "Dojo Staff",
    "slug": "dojo-staff",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dojo-staff",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dojomanager.staff",
      "infoPlist": {
        "NSCameraUsageDescription": "Scan member QR codes for check-in"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.dojomanager.staff",
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan member QR codes for check-in"
        }
      ],
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "apiUrl": "http://localhost:3000"
    }
  }
}
