rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow authenticated users to read and write everything
    // WARNING: This is for development only. Tighten these rules for production.
    // Allow checking if any admin exists for setup wizard
    match /users/{userId} {
      allow read: if request.auth != null || (
        request.query.limit <= 1 && 
        request.query.filters.size() == 1 && 
        request.query.filters[0].field == "role" && 
        request.query.filters[0].op == "==" && 
        request.query.filters[0].value == "admin"
      );
    }

    // Allow public access to general settings (for logo/name on login)
    match /settings/general {
      allow read: if true;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Specific rules examples (can be enabled later):
    // match /users/{userId} {
    //   allow read, write: if request.auth != null && request.auth.uid == userId;
    // }
  }
}
