# PostgreSQL connection (DigitalOcean Managed Database)
DATABASE_URL=postgresql://user:password@host:25060/mma_manager?sslmode=require
DATABASE_SSL=true

# JWT secret (generate a strong random string)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=7d

# Platform super admin (created on first startup if not exists)
PLATFORM_ADMIN_EMAIL=admin@platform.com
PLATFORM_ADMIN_PASSWORD=change-this-password

# Server
PORT=3000
API_PORT=3000
NODE_ENV=production

# File uploads directory (use DO Spaces volume mount in production)
UPLOAD_DIR=./uploads

# CORS (set to your domain in production)
CORS_ORIGIN=https://your-domain.com
