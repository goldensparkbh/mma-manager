# PostgreSQL connection (DigitalOcean Managed Database)
DATABASE_URL=postgresql://user:password@host:25060/mma_manager?sslmode=require
DATABASE_SSL=true

# JWT secret (generate a strong random string)
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES=7d

# Platform super admin — synced on every server start (create or update password)
PLATFORM_ADMIN_EMAIL=admin@platform.com
PLATFORM_ADMIN_PASSWORD=change-this-password
# If an admin already exists with a different email, set true once to take over:
# PLATFORM_ADMIN_FORCE_SYNC=true

# Server
PORT=3000
API_PORT=3000
NODE_ENV=production

# Public app URL (used for TAP redirect/webhook URLs)
APP_URL=https://your-domain.com

# File uploads — choose ONE for production:
# 1) DigitalOcean Spaces (recommended, survives deploys):
# SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# SPACES_REGION=nyc3
# SPACES_BUCKET=your-space-name
# SPACES_ACCESS_KEY_ID=
# SPACES_SECRET_ACCESS_KEY=
# SPACES_CDN_URL=https://your-space-name.nyc3.cdn.digitaloceanspaces.com
# 2) Or mount a persistent volume at UPLOAD_DIR in App Platform
UPLOAD_DIR=./uploads

# CORS (set to your domain in production)
CORS_ORIGIN=https://your-domain.com

# TAP Payments — get keys at https://os.tap.company (Developers → API Keys)
TAP_SECRET_KEY=sk_test_YOUR_KEY_FROM_TAP_DASHBOARD
TAP_SOURCE_ID=src_all
TAP_CURRENCY=BHD
TAP_PHONE_COUNTRY_CODE=973

# Dev only — skip TAP and instantly activate member package purchases (remove in production)
# FAKE_MEMBER_PAYMENTS=true

# SMTP for trial/payment invoice emails
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notifications@example.com
SMTP_PASS=your-smtp-password
SMTP_FROM="Nawady <notifications@example.com>"

# Mobile apps (Expo) — set in apps/dojo-member/.env and EAS secrets
EXPO_PUBLIC_API_URL=https://your-api.example.com
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Places (New) + Geocoding — enable "Places API (New)" in Google Cloud Console
# Used by: db:import:places, db:geocode:clubs
GOOGLE_PLACES_API_KEY=

# SMS (Twilio-compatible) — optional, used for OTP and notifications
SMS_ACCOUNT_SID=
SMS_AUTH_TOKEN=
SMS_FROM_NUMBER=
